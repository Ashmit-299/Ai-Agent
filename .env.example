# AI Content Uploader Environment Variables

# Database Configuration
# For local development (SQLite)
DATABASE_URL=sqlite:///./ai_agent.db

# For production (PostgreSQL/Supabase) - uncomment and update
# DATABASE_URL=postgresql://user:password@host:port/database

# JWT Secret
JWT_SECRET_KEY=your-jwt-secret-key-here
JWS_SECRET=your-jws-secret-key-here

# External API Keys
POSTHOG_API_KEY=your-posthog-key
SENTRY_DSN=your-sentry-dsn

# LLM API Keys
PERPLEXITY_API_KEY=your-perplexity-key
BHIV_LM_URL=http://localhost:8001
BHIV_LM_API_KEY=demo_api_key_123

# Storage Backend
BHIV_STORAGE_BACKEND=local
BHIV_BUCKET_PATH=bucket

# Optional: AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
BHIV_S3_BUCKET=your-bucket-name
BHIV_S3_REGION=us-east-1