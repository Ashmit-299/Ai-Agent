# AI-Agent: Enhanced Environment Configuration
# ⚠️  CRITICAL: Never commit actual secrets to version control

# =============================================================================
# 🔐 SECURITY & AUTHENTICATION
# =============================================================================

# JWT Configuration (REQUIRED)
JWT_SECRET_KEY=your-super-secure-jwt-secret-key-min-32-chars
JWS_SECRET=your-jws-secret-key-for-additional-security
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-from-dashboard

# Password Security
MIN_PASSWORD_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=900

# =============================================================================
# 🗄️  DATABASE CONFIGURATION
# =============================================================================

# Development (SQLite)
DATABASE_URL=sqlite:///./data/ai_agent.db

# Production (PostgreSQL/Supabase)
# DATABASE_URL=postgresql://user:password@host:port/database
# Example: postgresql://postgres:password@db.supabase.co:5432/postgres

# =============================================================================
# 📊 OBSERVABILITY & MONITORING
# =============================================================================

# Sentry Error Tracking (RECOMMENDED for production)
SENTRY_DSN=your-sentry-dsn-from-project-settings
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# PostHog Analytics (RECOMMENDED for user insights)
POSTHOG_API_KEY=your-posthog-api-key
POSTHOG_HOST=https://us.posthog.com
POSTHOG_ENABLED=true

# =============================================================================
# 🤖 AI & LLM INTEGRATION
# =============================================================================

# Perplexity AI (for enhanced content analysis)
PERPLEXITY_API_KEY=your-perplexity-api-key

# Local LLM Server (optional)
BHIV_LM_URL=http://localhost:8001
BHIV_LM_API_KEY=demo_api_key_123
BHIV_LM_ENABLED=false

# =============================================================================
# 💾 STORAGE CONFIGURATION
# =============================================================================

# Local Storage (default)
BHIV_STORAGE_BACKEND=local
BHIV_BUCKET_PATH=bucket
MAX_FILE_SIZE_MB=100
ALLOWED_FILE_EXTENSIONS=.mp4,.mp3,.wav,.jpg,.jpeg,.png,.txt,.pdf

# AWS S3 (optional - for production scale)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# BHIV_S3_BUCKET=your-s3-bucket-name
# BHIV_S3_REGION=us-east-1

# =============================================================================
# 🌐 APPLICATION SETTINGS
# =============================================================================

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=1

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_METHODS=GET,POST,PUT,DELETE
ALLOWED_HEADERS=*

# =============================================================================
# 🔧 FEATURE FLAGS
# =============================================================================

# Enable/disable features
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=false
ENABLE_RATE_LIMITING=true
ENABLE_ANALYTICS=true
ENABLE_VIDEO_GENERATION=true

# =============================================================================
# 📝 SETUP INSTRUCTIONS
# =============================================================================

# 1. Copy this file to .env: cp .env.example .env
# 2. Replace all 'your-*' values with actual credentials
# 3. For production, use strong secrets (32+ characters)
# 4. Never commit .env file to version control
# 5. Use environment-specific values for different deployments

# 🔗 Get your credentials:
# - Supabase: https://supabase.com/dashboard
# - Sentry: https://sentry.io/settings/projects/
# - PostHog: https://app.posthog.com/project/settings
# - Perplexity: https://www.perplexity.ai/settings/api